rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------- Primitives & Helper Functions -----------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'chines@trader.com' || 
        request.auth.token.email == 'estrategiachinesa@gmail.com' ||
        request.auth.token.email == 'traderchinesvip@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isChangingSubscription() {
      return incoming().subscriptionStatus != existing().subscriptionStatus;
    }

    // ----------------- Entity Validation Blueprints -----------------
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'createdAt', 'userOrigin']) &&
             data.keys().size() <= 12 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is string &&
             data.userOrigin is string && (data.userOrigin == 'ANALYZER' || data.userOrigin == 'COPY') &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('subscriptionStatus' in data) || (data.subscriptionStatus is string && (data.subscriptionStatus == 'ACTIVE' || data.subscriptionStatus == 'INACTIVE' || data.subscriptionStatus == 'CANCELED'))) &&
             (!('accountStatus' in data) || (data.accountStatus is string && (data.accountStatus == 'ACTIVE' || data.accountStatus == 'DISABLED'))) &&
             (!('termsAccepted' in data) || data.termsAccepted is bool) &&
             (!('termsAcceptedAt' in data) || data.termsAcceptedAt is string) &&
             (!('lastHotmartStatus' in data) || (data.lastHotmartStatus is string && data.lastHotmartStatus.size() <= 50)) &&
             (!('lastHotmartUpdate' in data) || data.lastHotmartUpdate is string) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5));
    }

    function isValidVipRequest(data) {
      return data.keys().hasAll(['brokerId', 'userId', 'status', 'submittedAt']) &&
             data.keys().size() <= 6 &&
             data.brokerId is string && data.brokerId.size() >= 8 && data.brokerId.size() <= 32 && data.brokerId.matches('^[0-9]+$') &&
             data.userId is string && data.userId.size() <= 128 &&
             data.status is string && (data.status == 'PENDING' || data.status == 'AWAITING_DEPOSIT' || data.status == 'DEPOSIT_PENDING' || data.status == 'APPROVED' || data.status == 'REJECTED' || data.status == 'PREMIUM') &&
             data.submittedAt is string &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 256));
    }

    function isValidCopyRequest(data) {
      return data.keys().hasAll(['email', 'brokerId', 'status', 'submittedAt']) &&
             data.keys().size() <= 9 &&
             data.email is string && data.email.size() <= 256 &&
             data.brokerId is string && data.brokerId.size() <= 64 &&
             data.status is string && (data.status == 'PENDING' || data.status == 'APPROVED' || data.status == 'ERROR_LIQUIDITY' || data.status == 'REJECTED' || data.status == 'AWAITING_DEPOSIT' || data.status == 'DEPOSIT_PENDING' || data.status == 'AUTHORIZED' || data.status == 'REGISTERED') &&
             data.submittedAt is string &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('password' in data) || (data.password is string && data.password.size() <= 100)) &&
             (!('registeredAt' in data) || data.registeredAt is string) &&
             (!('telegram' in data) || (data.telegram is string && data.telegram.size() <= 100)) &&
             (!('hasBalance' in data) || data.hasBalance is bool);
    }

    function isValidAppConfig(data) {
      return (!('registrationSecret' in data) || (data.registrationSecret is string && data.registrationSecret.size() <= 256)) &&
             (!('supportUrl' in data) || (data.supportUrl is string && data.supportUrl.size() <= 1024)) &&
             (!('hourlySignalLimit' in data) || data.hourlySignalLimit is number) &&
             (!('newsWarningDuration' in data) || data.newsWarningDuration is number) &&
             (!('otcExcellentFrequency' in data) || data.otcExcellentFrequency is number);
    }

    // ----------------- Match Blocks -----------------

    /**
     * Rules for App Configuration
     */
    match /appConfig/{configDoc} {
      allow read: if true;
      allow create, update: if (configDoc == 'analytics' && incoming().keys().size() <= 20) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * Rules for VIP Access Requests
     */
    match /vipRequests/{userId} {
      allow get: if isValidId(userId) && isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isValidId(userId) && isSignedIn() && isOwner(userId) && 
                      incoming().userId == request.auth.uid &&
                      incoming().status == 'PENDING' &&
                      isValidVipRequest(incoming());
      allow update: if isValidId(userId) && (
                      isAdmin() || (
                        isSignedIn() && isOwner(userId) && isValidVipRequest(incoming()) && (
                          // Action 1: User is updating brokerId and resetting status to PENDING
                          (incoming().status == 'PENDING' && incoming().diff(existing()).affectedKeys().hasAny(['brokerId']) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'brokerId', 'submittedAt', 'userId', 'userEmail'])) ||
                          // Action 2: User is confirming deposit (AWAITING_DEPOSIT -> DEPOSIT_PENDING)
                          (existing().status == 'AWAITING_DEPOSIT' && incoming().status == 'DEPOSIT_PENDING' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
                        )
                      )
                    );
      allow delete: if isValidId(userId) && (isAdmin() || (isSignedIn() && isOwner(userId)));
    }

    /**
     * Rules for Copy Trade Requests (Firestore-based Login)
     */
    match /copyRequests/{requestId} {
      allow read: if true; // Public read is required for unauthenticated login checks by brokerId
      allow create: if isAdmin();
      allow update: if isAdmin() || (
                      // Unauthenticated or authenticated users can update their Authorized status to Registered
                      existing().status == 'AUTHORIZED' &&
                      incoming().status == 'REGISTERED' &&
                      incoming().brokerId == existing().brokerId &&
                      isValidCopyRequest(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'registeredAt', 'name', 'email', 'password', 'hasBalance', 'telegram'])
                    );
      allow delete: if isAdmin();
    }

    /**
     * Main User Data Collection
     */
    match /users/{userId} {
      allow get: if isValidId(userId) && isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isValidId(userId) && (isAdmin() || (isSignedIn() && isOwner(userId) && isValidUserProfile(incoming())));
      allow update: if isValidId(userId) && (
                      isAdmin() || (
                        isSignedIn() && isOwner(userId) && isValidUserProfile(incoming()) && (
                          // Prevent user from changing critical fields like subscriptionStatus, accountStatus, rating
                          !isChangingSubscription() &&
                          (!('accountStatus' in existing()) || incoming().accountStatus == existing().accountStatus) &&
                          (!('rating' in existing()) || incoming().rating == existing().rating)
                        )
                      )
                    );
      allow delete: if isValidId(userId) && (isAdmin() || (isSignedIn() && isOwner(userId)));
    }

    /**
     * Rules for LGPD Consent Logs
     */
    match /consentLogs/{logId} {
      allow create: if isValidId(logId) && isSignedIn() && incoming().userId == request.auth.uid && incoming().keys().size() <= 10;
      allow read: if isValidId(logId) && (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid));
    }

    /**
     * Rules for LGPD Deletion Requests (for backend/admin tracking)
     */
    match /deletionRequests/{requestId} {
      allow create: if isValidId(requestId) && isSignedIn() && incoming().userId == request.auth.uid && incoming().keys().size() <= 10;
      allow read: if isValidId(requestId) && isAdmin();
    }

    /**
     * Rules for live session status and scoreboard
     */
    match /session/{sessionDoc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * Rules for affiliate links/settings
     */
    match /affiliates/{affDoc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
